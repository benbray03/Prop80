mutate(
lon = as.numeric(sub("(-?[0-9.]+)-(-?[0-9.]+)$", "\\1", cell_coord_id)),
lat = as.numeric(sub("(-?[0-9.]+)-(-?[0-9.]+)$", "\\2", cell_coord_id))
)
